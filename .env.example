# Telegram Bot API Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ID администраторов Telegram (через запятую, получить у @userinfobot)
TELEGRAM_ADMIN_IDS=123456789

# Режим запуска:
# USE_POLLING=true — для локальной разработки (по умолчанию)
# USE_WEBHOOK=true — для production (Vercel)
USE_POLLING=true

# URL для webhook (обязателен при USE_WEBHOOK=true)
WEBHOOK_URL=https://dk-grupp.vercel.app
